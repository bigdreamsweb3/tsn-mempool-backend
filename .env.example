# TSN Mempool — environment variables
# Copy this to .env and fill in your values

# Required: GitHub PAT with Contents:Write on bigdreamsweb3/tsn-epoch-records
GITHUB_TOKEN=ghp_your_token_here

# Required: Redis connection URL
REDIS_URL=redis://localhost:6379

# Optional: port to listen on (default 8000)
PORT=8000

# Optional: hours per epoch (default 7)
EPOCH_HOURS=7
