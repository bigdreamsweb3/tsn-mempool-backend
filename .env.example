# TSN Mempool — environment variables
# Copy this to .env and fill in your values

# Required: GitHub PAT with Contents:Write on bigdreamsweb3/tsn-epoch-records
GITHUB_TOKEN=ghp_your_token_here

# Required Firebase Admin credentials.
# TSN mempool live state is stored in Firebase Firestore.
MEMPOOL_STORE=firebase

# Option A: point to a Firebase service-account JSON file.
FIREBASE_CREDENTIALS=.fb_creds/your-firebase-adminsdk.json

# Option B: provide service-account fields directly.
FIREBASE_PROJECT_ID=tsn-mempool
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-your-service-account@tsn-mempool.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: Firestore root collection used by this service.
FIREBASE_COLLECTION=tsn_mempool

# Required: TSN escrow program to scan for CrankerVault accounts.
TSN_PROGRAM_ID=TSN31jddtsmUg4D5aEdhY31nwB1e53VJJg9X8NoRP8V
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: supported SPL tokens and valuation metadata used by /network/overview.
# unitPriceUsd is required when a stable token is not exactly $1, because active
# vault liquidity is reported in USD.
# SOLANA_ALLOWED_SPL_TOKENS=[{"mintAddress":"4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU","symbol":"USDC","name":"USD Coin","decimals":6,"unitPriceUsd":1}]

# Optional: port to listen on (default 8000)
PORT=8000

# Required outside local development. Shared only with trusted backend services
# and Cranker daemons; never expose this value to browser code.
MEMPOOL_API_KEY=

# Private settlement verifier secrets. The browser receives only the matching
# X25519 public key. Cranker daemons do not receive either secret.
TSN_ROUTE_ENCRYPTION_SECRET_KEY=
TSN_PERMIT_SIGNER_SECRET_KEY=
TSN_PRIVATE_PERMIT_TTL_SECS=90
TSN_LEASE_AUTH_MAX_AGE_SECS=60

# Optional: hours per epoch (default 7)
EPOCH_HOURS=7

# Recovery leases are short-lived so another Cranker can recover abandoned work.
RECOVERY_LEASE_SECS=300
RECOVERY_REWARD_LAMPORTS=10000

# Recovery jobs for settlement Crankers below this token liquidity receive
# priority so depleted vaults are replenished before healthy vaults.
RECOVERY_LOW_LIQUIDITY_UI=10
RECOVERY_LOW_LIQUIDITY_UI=0
