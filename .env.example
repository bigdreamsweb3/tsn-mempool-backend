# TSN Mempool — environment variables
# Copy this to .env and fill in your values

# ── STORAGE: Choose ONE ────────────────────────────────────────────────

# Option 1: Redis (default)
REDIS_URL=redis://localhost:6379

# Option 2: Firebase Firestore (uncomment and configure to use)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY="---BEGIN PRIVATE KEY-----\n..."

# ── Other Settings ────────────────────────────────────────────────────

# Required: GitHub PAT for epoch records
GITHUB_TOKEN=ghp_your_token_here

# Optional: port (default 8000)
PORT=8000

# Optional: hours per epoch (default 7)
EPOCH_HOURS=7
